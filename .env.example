# ── 백엔드 설정 ──
# cli (기본값) 또는 api
LLM_BACKEND=cli

# ── CLI 모드 설정 ──
# claude (기본값) 또는 codex
LLM_PROVIDER=claude

# ── API 모드 설정 ──
# LiteLLM 모델명 (--backend api 사용 시)
LLM_MODEL=claude-sonnet-4-20250514

# API 키 (사용할 프로바이더의 키만 설정)
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIzaSy...
# OPENAI_API_KEY=sk-...
